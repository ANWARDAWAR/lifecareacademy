{"success":true,"data":[{"id":"fire-safety","title":"Fire Safety Training","category":"Fire Safety","image":"/fire_safety.png","duration":"3 Days","fee":"12,000 PKR","shortDescription":"Comprehensive fire safety training covering prevention, risk assessment, extinguisher use, and emergency procedures.","overview":"Fire safety is a foundational requirement for every workplace. This practical program equips participants to identify hazards, prevent incidents, and respond effectively during fire emergencies.","learn":["Understand the Fire Triangle and key ignition risks","Use the PASS method for extinguisher operation","Execute evacuation plans and assembly procedures","Perform practical risk assessments for high-risk areas"],"modules":["Fire Prevention Fundamentals","Emergency Response and Evacuation","Hands-on Extinguisher Practice","Workplace Fire Risk Assessment"]},{"id":"othm-level-6","title":"OTHM Level 6 Diploma in OHS","category":"Management","image":"/OTHM.png","duration":"10 Days (Intensive Workshop)","fee":"290,000 PKR","shortDescription":"Advanced qualification focused on strategic safety leadership and professional progression.","overview":"The OTHM Level 6 Diploma is equivalent to a bachelor-level qualification and designed for professionals moving into senior health and safety leadership roles.","learn":["Build strategic frameworks for health and safety governance","Develop policy-level decision-making and leadership skills","Strengthen readiness for GradIOSH progression pathways","Align organizational practice with international standards"],"modules":["Strategic Safety Management","Leadership and Organizational Culture","Policy, Compliance, and Governance","Applied Case Analysis and Professional Practice"]},{"id":"iosh-managing-safely","title":"IOSH Managing Safely","category":"Management","image":"/IOSH.png","duration":"4 Days (22 Hours)","fee":"25,000 PKR","shortDescription":"Practical IOSH certification for supervisors and managers handling daily safety responsibilities.","overview":"IOSH Managing Safely is one of the most recognized manager-level safety certifications globally, focused on practical risk management and performance improvement.","learn":["Apply risk assessment in everyday operations","Investigate incidents and identify root causes","Measure and improve safety performance in teams","Create accountability at supervisory and management levels"],"modules":["Introducing Managing Safely","Assessing and Controlling Risks","Understanding Responsibilities","Measuring and Improving Performance"]},{"id":"osha-construction","title":"OSHA (General and Construction)","category":"Construction","image":"/OSHA.png","duration":"8 Days","fee":"20,000 PKR","shortDescription":"Comprehensive OSHA-focused training for general and construction industry professionals.","overview":"This OSHA program trains participants on internationally recognized safety standards used in high-risk sectors including construction, industrial operations, and infrastructure projects.","learn":["Interpret OSHA principles for practical implementation","Control hazards in general industry and construction settings","Improve lifting, height, and site risk management","Strengthen incident prevention in high-risk operations"],"modules":["General Industry Safety and Health","Construction Industry Safety and Health","Cranes and Lifting Safety","Working at Heights and Site Hazard Control"]},{"id":"iso-management","title":"ISO Management Systems","category":"Compliance","image":"/ISO.png","duration":"7 Days","fee":"85,000 PKR","shortDescription":"ISO 45001, ISO 14001, and integrated management systems for auditors and implementers.","overview":"An advanced ISO program designed for professionals implementing and auditing occupational health, safety, and environmental management systems.","learn":["Implement ISO 45001 and ISO 14001 frameworks","Build integrated management system documentation","Conduct internal audits with evidence-based methods","Improve operational compliance and continual improvement"],"modules":["ISO 45001 Interpretation and Application","ISO 14001 Environmental Controls","Integrated Management System Design","Internal Audit and Corrective Action Planning"]},{"id":"highfield-hiqual-qualifications","title":"Highfield (HiQual) Qualifications","category":"Compliance","image":"/HiQual.png","duration":"Flexible (Varies by Level)","fee":"Contact for details","shortDescription":"Internationally benchmarked Highfield qualifications designed to strengthen compliance capability, workforce competence, and audit readiness across regulated environments.","overview":"The Highfield (HiQual) pathway supports professionals and organizations in building dependable competence against recognized compliance frameworks. With level-based progression and practical assessment focus, this program helps teams align operational controls, documentation, and workforce behavior with modern regulatory expectations.","learn":["Interpret Highfield qualification standards and apply them in operational compliance workflows","Design evidence-based documentation practices that withstand internal and external audits","Embed compliance culture through role-based accountability and practical supervision tools","Plan level-wise professional progression aligned with organizational and sector requirements"],"modules":["Highfield Standards and Qualification Pathways","Compliance Documentation and Evidence Management","Operational Controls and Assurance Practices","Assessment Strategy and Continuous Improvement"]},{"id":"oshas-safety-certification","title":"OSHAS Safety Certification","category":"Management","image":"/OSHAS.png","duration":"5 Days","fee":"Contact for details","shortDescription":"A management-oriented OSHAS certification that develops practical leadership competence for governing workplace risk, safety performance, and regulatory confidence.","overview":"This intensive OSHAS Safety Certification is built for supervisors, managers, and HSE leads who are responsible for translating policy into measurable site-level outcomes. Participants gain practical systems for risk governance, incident prevention, and performance assurance that can be applied immediately within multi-disciplinary operations.","learn":["Establish robust safety governance structures that support managerial decision-making","Apply proactive risk controls using incident data, trend indicators, and root-cause analysis","Lead cross-functional teams with clear safety accountability and communication protocols","Measure and improve safety performance through practical KPIs and action planning"],"modules":["OSHAS Frameworks and Management Responsibilities","Risk Control Systems and Preventive Planning","Incident Investigation and Corrective Action","Safety Performance Metrics and Leadership Practice"]},{"id":"professional-first-aid","title":"Professional First Aid Certification","category":"First Aid","image":"/FIRSTAID.png","duration":"3 Days","fee":"12,000 PKR","shortDescription":"Hands-on first aid course covering CPR, emergency response, and injury management.","overview":"This practical first aid certification builds confidence to respond quickly and correctly in emergency situations at work, home, and public environments.","learn":["Perform immediate emergency scene assessment","Administer CPR and choking response protocols","Treat burns, bleeding, fractures, and shock","Apply practical first response in real scenarios"],"modules":["Emergency Response Basics","CPR and Airway Management","Injury and Trauma Management","Practical Drills and Scenario Assessment"]}]}